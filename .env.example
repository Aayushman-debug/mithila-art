# ── Frontend ──────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:5000
VITE_GOOGLE_CLIENT_ID=your_google_client_id
VITE_FACEBOOK_APP_ID=your_facebook_app_id

# ── Backend: Core ─────────────────────────────────────────────
PORT=5000
MONGODB_URI=your-mongodb-connection-string
JWT_SECRET=your_jwt_secret_here_min_32_chars
BACKEND_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173
FRONTEND_URLS=http://localhost:3000,http://localhost:5173,https://your-netlify-site.netlify.app

# ── Backend: Razorpay ─────────────────────────────────────────
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ── Backend: Google OAuth ─────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id

# ── Backend: Facebook OAuth ───────────────────────────────────
# Get these from https://developers.facebook.com/apps → Settings → Basic
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# ── Backend: Email (Brevo SMTP) ───────────────────────────────
BREVO_SMTP_LOGIN=your_brevo_smtp_login
BREVO_SMTP_PASSWORD=your_brevo_smtp_password
EMAIL_FROM="Mithila Art <no-reply@mithilaart.com>"

# ── Backend: Cloudinary ───────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
